{
	"name": "project-happy-home",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --webpack",
		"build:sw": "esbuild src/service-worker/sw.ts --outdir=public --minify --bundle",
		"build": "npm run build:sw && next build --webpack",
		"start": "next start",
		"typecheck": "tsgo -p tsconfig.json",
		"typecheck-sw": "tsgo -p src/service-worker/tsconfig.json",
		"knip": "knip",
		"lint": "oxlint",
		"test": "npm run typecheck && npm run typecheck-sw && npm run knip && npm run lint",
		"typecheck-old": "tsc -p tsconfig.json",
		"typecheck-sw-old": "tsc -p src/service-worker/tsconfig.json",
		"lint-old": "eslint .",
		"test-all": "npm run test && npm run typecheck-old && npm run typecheck-sw-old && npm run lint-old"
	},
	"dependencies": {
		"@auth/core": "^0.37.4",
		"@convex-dev/auth": "^0.0.91",
		"@vanilla-extract/css": "^1.17.2",
		"@vanilla-extract/dynamic": "^2.1.5",
		"@vanilla-extract/recipes": "^0.5.5",
		"arktype": "^2.2.0",
		"canvas-confetti": "^1.9.3",
		"classnames": "^2.5.1",
		"convex": "^1.31.1",
		"next": "^16.1.1",
		"nuqs": "^2.4.3",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@convex-dev/eslint-plugin": "^1.1.1",
		"@eslint/js": "^9.39.2",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.0",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/web-push": "^3.6.4",
		"@typescript/native-preview": "^7.0.0-dev.20260321.1",
		"@vanilla-extract/next-plugin": "^2.4.11",
		"esbuild": "^0.27.2",
		"eslint": "^9.39.2",
		"eslint-config-next": "^16.1.1",
		"knip": "^6.0.1",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.1",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.51.0"
	}
}
